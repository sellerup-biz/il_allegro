# IL_Allegro — какие ключи нужны.
# В реальности секреты лежат в GitHub Secrets репозитория il_allegro,
# а не в этом файле. Локальный .env нужен только если запускаешь скрипты у себя.

# --- Allegro app (IL_read) ---
CLIENT_ID_IL=
CLIENT_SECRET_IL=
REFRESH_TOKEN_IL=          # записывается автоматически после авторизации

# --- GitHub PAT (Actions + Secrets: read/write) ---
# Используется workflow'ами для сохранения/ротации refresh_token.
GH_TOKEN=
